{
    "name": "ipedis/rabbit-client",
    "description": "Event and Order client library",
    "type": "library",
    "authors": [
        {
            "name": "Yanis Ghidouche",
            "email": "yanis@ipedis.com"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": ">=7.4",
        "ext-json": "*",
        "symfony/polyfill-uuid": "^1.14",
        "opis/json-schema": "^1.0",
        "ext-amqp": "^1.9",
        "guzzlehttp/guzzle": "~6.0",
        "ipedis/http-signature": "^1.0.0",
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "psr-4": {
            "Ipedis\\Rabbit\\": "src/",
            "Ipedis\\Demo\\Rabbit\\": "demo/",
	    "Ipedis\\Test\\Rabbit\\": "tests"
        }
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "bitbucket:ipedis/http-signature.git"
        }
    ],
    "extra": {
        "hooks": {
            "pre-commit": [
                "./vendor/bin/php-cs-fixer fix ."
            ]
        }
    },
    "scripts": {
        "test": "pest tests",
        "lint": "php-cs-fixer fix ."
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "brainmaestro/composer-git-hooks": "^2.8",
        "pestphp/pest": "^1.15"
    }
}
