{
    "name": "ipedis/rabbit-client",
    "description": "Event and Order client library",
    "type": "library",
    "authors": [
        {
            "name": "Yanis Ghidouche",
            "email": "yanis@ipedis.com"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.2",
        "ext-json": "*",
        "ext-amqp": "*",
        "symfony/polyfill-uuid": "^1.14",
        "opis/json-schema": "^2.6",
        "guzzlehttp/guzzle": "~7.0",
        "ipedis/http-signature": "^2.1.0",
        "filp/whoops": "^2.18"
    },
    "autoload": {
        "psr-4": {
            "Ipedis\\Rabbit\\": "src/",
            "Ipedis\\Demo\\Rabbit\\": "demo/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ipedis\\Test\\Rabbit\\": "tests/"
        }
    },
    "require-dev": {
        "rector/rector": "^2.3",
        "phpunit/phpunit": "^11.5",
        "phpstan/phpstan": "^2.1",
        "laravel/pint": "^1.19",
        "phpstan/phpstan-strict-rules": "^2.0"
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html coverage",
        "phpstan": "phpstan analyse --memory-limit 2024M",
        "pint": "pint",
        "pint:check": "pint --test",
        "rector": "rector process",
        "rector:check": "rector process --dry-run",
        "qa": [
            "@rector",
            "@pint",
            "@phpstan",
            "@test"
        ]
    }
}
