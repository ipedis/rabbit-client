{
    "name": "ipedis/rabbit-client",
    "description": "Event and Order client library",
    "type": "library",
    "authors": [
        {
            "name": "Yanis Ghidouche",
            "email": "yanis@ipedis.com"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.4",
        "ext-json": "*",
        "symfony/polyfill-uuid": "^1.14",
        "opis/json-schema": "^2.6",
        "ext-amqp": "*",
        "guzzlehttp/guzzle": "~7.0",
        "ipedis/http-signature": "^3.0.0",
        "phpunit/phpunit": "^12.5",
        "filp/whoops": "^2.18"
    },
    "autoload": {
        "psr-4": {
            "Ipedis\\Rabbit\\": "src/",
            "Ipedis\\Demo\\Rabbit\\": "demo/",
	        "Ipedis\\Test\\Rabbit\\": "tests"
        }
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/ipedis/http-signature.git"
        }
    ],
    "extra": {
        "hooks": {
            "pre-commit": [
                "./vendor/bin/php-cs-fixer fix ."
            ]
        }
    },
    "scripts": {
        "test": "pest tests",
        "lint": "php-cs-fixer fix ."
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "brainmaestro/composer-git-hooks": "^3.0",
        "pestphp/pest": "^4.3",
        "rector/rector": "^2.3"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": false
        }
    }
}
